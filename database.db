-- Create database
CREATE DATABASE fitness_tracker;
\c fitness_tracker;

-- Enable UUID extension for better ID generation
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";

-- =====================================================
-- ENUMS AND LOOKUP TABLES
-- =====================================================

-- Exercise categories/lookup table
CREATE TABLE exercise_categories (
    id SERIAL PRIMARY KEY,
    name VARCHAR(50) UNIQUE NOT NULL,
    description TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Insert default categories
INSERT INTO exercise_categories (name, description) VALUES
    ('Push', 'Weight training and resistance exercises'),
    ('Pull', 'Cardiovascular exercises'),
    ('Legs', 'Stretching and mobility work');

-- Muscle groups lookup
CREATE TABLE muscle_groups (
    id SERIAL PRIMARY KEY,
    name VARCHAR(50) UNIQUE NOT NULL
);

INSERT INTO muscle_groups (name) VALUES
    ('Chest'), ('Back'), ('Shoulders'), ('Biceps'), ('Triceps'),
    ('Quadriceps'), ('Hamstrings'), ('Glutes'), ('Calves'), ('Abs'),
    ('Forearms'), ('Traps'), ('Lats'), ('Lower Back');

-- =====================================================
-- MAIN TABLES
-- =====================================================

-- Exercises master table
CREATE TABLE exercises (
    id SERIAL PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    description TEXT,
    category_id INTEGER REFERENCES exercise_categories(id),
    is_custom BOOLEAN DEFAULT false,
    created_by VARCHAR(100), -- User ID or 'system'
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    UNIQUE(name, created_by)
);

-- Exercise-muscle group junction table (many-to-many)
CREATE TABLE exercise_muscle_groups (
    exercise_id INTEGER REFERENCES exercises(id) ON DELETE CASCADE,
    muscle_group_id INTEGER REFERENCES muscle_groups(id) ON DELETE CASCADE,
    is_primary BOOLEAN DEFAULT true,
    PRIMARY KEY (exercise_id, muscle_group_id)
);

-- =====================================================
-- WORKOUT TRACKING TABLES
-- =====================================================

-- Workout sessions (can contain multiple exercises)
CREATE TABLE workout_sessions (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    session_date DATE NOT NULL,
    notes TEXT, -- Overall workout notes
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Index for date-based queries
CREATE INDEX idx_workout_sessions_date ON workout_sessions(session_date);

-- Individual exercises performed in a workout
CREATE TABLE workout_exercises (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    workout_session_id UUID REFERENCES workout_sessions(id) ON DELETE CASCADE,
    exercise_id INTEGER REFERENCES exercises(id),
    order_number INTEGER NOT NULL, -- Order in the workout
    notes TEXT, -- Exercise-specific notes
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    UNIQUE(workout_session_id, order_number)
);

-- Individual sets for each exercise
CREATE TABLE exercise_sets (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    workout_exercise_id UUID REFERENCES workout_exercises(id) ON DELETE CASCADE,
    set_number INTEGER NOT NULL,
    reps INTEGER,
    weight DECIMAL(6,2), -- in kg/lbs (you decide unit)
    weight_unit VARCHAR(3) DEFAULT 'kg', -- 'kg' or 'lbs'
    comment TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    UNIQUE(workout_exercise_id, set_number)
);

-- =====================================================
-- RUNNING TRACKING TABLES
-- =====================================================

-- Running sessions
CREATE TABLE running_sessions (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    session_date DATE NOT NULL,
    start_time TIME,
    end_time TIME,
    distance DECIMAL(6,2) NOT NULL, -- in kilometers
    distance_unit VARCHAR(3) DEFAULT 'km',
    duration INTERVAL NOT NULL, -- PostgreSQL interval type
    avg_heart_rate INTEGER CHECK (avg_heart_rate >= 30 AND avg_heart_rate <= 250),
    max_heart_rate INTEGER CHECK (max_heart_rate >= 30 AND max_heart_rate <= 250),
    avg_pace INTERVAL, -- Calculated from distance/duration
    calories_burned INTEGER,
    notes TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Index for date-based queries
CREATE INDEX idx_running_sessions_date ON running_sessions(session_date);

-- =====================================================
-- SAMPLE DATA INSERTION
-- =====================================================

-- Insert sample exercises
INSERT INTO exercises (name, category_id, description, is_custom) VALUES
    ('Bench Press', (SELECT id FROM exercise_categories WHERE name = 'Strength'), 'Classic chest exercise', false),
    ('Squat', (SELECT id FROM exercise_categories WHERE name = 'Strength'), 'Compound leg exercise', false),
    ('Deadlift', (SELECT id FROM exercise_categories WHERE name = 'Strength'), 'Full body compound exercise', false),
    ('Pull-ups', (SELECT id FROM exercise_categories WHERE name = 'Strength'), 'Back and biceps exercise', false),
    ('Running', (SELECT id FROM exercise_categories WHERE name = 'Cardio'), 'Outdoor or treadmill running', false),
    ('Shoulder Press', (SELECT id FROM exercise_categories WHERE name = 'Strength'), 'Overhead pressing movement', false);

-- Link exercises to muscle groups
-- Bench Press (Chest primary, Triceps secondary, Shoulders secondary)
INSERT INTO exercise_muscle_groups (exercise_id, muscle_group_id, is_primary) VALUES
    (1, (SELECT id FROM muscle_groups WHERE name = 'Chest'), true),
    (1, (SELECT id FROM muscle_groups WHERE name = 'Triceps'), false),
    (1, (SELECT id FROM muscle_groups WHERE name = 'Shoulders'), false);

-- Squat (Quadriceps primary, Glutes secondary, Hamstrings secondary)
INSERT INTO exercise_muscle_groups (exercise_id, muscle_group_id, is_primary) VALUES
    (2, (SELECT id FROM muscle_groups WHERE name = 'Quadriceps'), true),
    (2, (SELECT id FROM muscle_groups WHERE name = 'Glutes'), false),
    (2, (SELECT id FROM muscle_groups WHERE name = 'Hamstrings'), false);
